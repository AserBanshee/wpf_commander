<Window x:Class="FileVault.Views.NamePrompt"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новая папка" Height="160" Width="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E2E">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="LabelText" Grid.Row="0"
                   Foreground="#CDD6F4" FontSize="13"/>

        <TextBox x:Name="InputBox" Grid.Row="2"
                 Background="#313244" Foreground="#CDD6F4"
                 BorderBrush="#585B70" BorderThickness="1"
                 Padding="8,5" FontSize="13">
            <TextBox.InputBindings>
                <KeyBinding Key="Return" Command="{x:Null}"
                            CommandParameter="{x:Null}"/>
            </TextBox.InputBindings>
        </TextBox>

        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="ОК" Width="80" Margin="0,0,8,0"
                    Click="Ok_Click"
                    Background="#89B4FA" Foreground="#1E1E2E"
                    FontWeight="SemiBold" BorderThickness="0"
                    Padding="0,6"/>
            <Button Content="Отмена" Width="80"
                    Click="Cancel_Click"
                    Background="#45475A" Foreground="#CDD6F4"
                    BorderThickness="0" Padding="0,6"/>
        </StackPanel>
    </Grid>
</Window>
