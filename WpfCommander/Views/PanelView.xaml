<UserControl x:Class="WpfCommander.Views.PanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border BorderThickness="2" CornerRadius="4">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource PanelAccent}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <DockPanel Background="{StaticResource PanelBackground}">

            <Grid DockPanel.Dock="Top" Margin="8,8,8,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ComboBox Grid.Column="0"
                          Width="80"
                          Margin="0,0,6,0"
                          ItemsSource="{Binding Drives}"
                          SelectedItem="{Binding SelectedDrive}"/>

                <TextBox Grid.Column="1"
                         IsReadOnly="True"
                         Text="{Binding CurrentPath, Mode=OneWay}"
                         VerticalContentAlignment="Center"
                         Background="{StaticResource WindowBackground}"
                         BorderBrush="{StaticResource PanelBorder}"
                         Padding="6,4"/>
            </Grid>

            <Border DockPanel.Dock="Bottom"
                    Background="{StaticResource WindowBackground}"
                    BorderBrush="{StaticResource PanelBorder}"
                    BorderThickness="0,1,0,0"
                    Padding="8,4">
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="11"
                           Foreground="{StaticResource Muted}"/>
            </Border>

            <DataGrid x:Name="ItemsGrid"
                      ItemsSource="{Binding Items}"
                      SelectedItem="{Binding SelectedItem}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      IsReadOnly="True"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow"
                      HeadersVisibility="Column"
                      GridLinesVisibility="None"
                      RowHeight="24"
                      Background="{StaticResource PanelBackground}"
                      AlternatingRowBackground="{StaticResource AltRow}"
                      BorderThickness="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      SelectionChanged="OnSelectionChanged"
                      MouseDoubleClick="OnRowDoubleClick"
                      KeyDown="OnKeyDown">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Имя" Width="*" SortMemberPath="Name">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}" Width="22" Margin="4,0,2,0"/>
                                    <TextBlock Text="{Binding DisplayName}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Тип"
                                        Binding="{Binding Type}"
                                        Width="80"/>
                    <DataGridTextColumn Header="Размер"
                                        Binding="{Binding SizeDisplay}"
                                        Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Margin" Value="0,0,8,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Дата"
                                        Binding="{Binding ModifiedDisplay}"
                                        Width="140"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Border>
</UserControl>
