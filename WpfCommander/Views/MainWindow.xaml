<Window x:Class="WpfCommander.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WpfCommander.ViewModels"
        xmlns:local="clr-namespace:WpfCommander.Views"
        Title="WPF Commander"
        Height="640" Width="1100"
        MinHeight="420" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackground}"
        FontFamily="Segoe UI"
        FontSize="13">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding CopyCommand}"/>
        <KeyBinding Key="F6" Command="{Binding MoveCommand}"/>
        <KeyBinding Key="F7" Command="{Binding NewFolderCommand}"/>
        <KeyBinding Key="F8" Command="{Binding DeleteCommand}"/>
    </Window.InputBindings>

    <DockPanel>

        <Border DockPanel.Dock="Bottom"
                Background="#E8E8EC"
                BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="0,1,0,0"
                Padding="8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="F5  Копировать"  Command="{Binding CopyCommand}"      Style="{StaticResource ToolbarButton}"/>
                <Button Content="F6  Переместить" Command="{Binding MoveCommand}"      Style="{StaticResource ToolbarButton}"/>
                <Button Content="F7  Новая папка" Command="{Binding NewFolderCommand}" Style="{StaticResource ToolbarButton}"/>
                <Button Content="F8  Удалить"     Command="{Binding DeleteCommand}"    Style="{StaticResource ToolbarButton}"/>
            </StackPanel>
        </Border>

        <Grid Margin="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="280"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*" MinWidth="280"/>
            </Grid.ColumnDefinitions>

            <local:PanelView x:Name="LeftPanelView"
                             Grid.Column="0"
                             DataContext="{Binding LeftPanel}"
                             GotKeyboardFocus="OnPanelGotFocus"
                             PreviewMouseDown="OnPanelPreviewMouseDown"/>

            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource PanelBorder}"/>

            <local:PanelView x:Name="RightPanelView"
                             Grid.Column="2"
                             DataContext="{Binding RightPanel}"
                             GotKeyboardFocus="OnPanelGotFocus"
                             PreviewMouseDown="OnPanelPreviewMouseDown"/>
        </Grid>
    </DockPanel>
</Window>
